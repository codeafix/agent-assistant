# Example config for running the same agent against the Anthropic API.
#
# Copy to agent.toml (or point at it via env vars, see below) and set
# ANTHROPIC_API_KEY in the environment. Everything else -- the loop, MCP
# tools, permissions, skills -- is unchanged from agent.toml.
#
# Equivalent without copying the file, override via env vars:
#   AGENT_MODEL__PROVIDER=anthropic \
#   AGENT_MODEL__NAME=claude-sonnet-4-6 \
#   AGENT_MODEL__API_KEY_ENV=ANTHROPIC_API_KEY \
#   uv run python -m agent "Please echo 'hello'."

[model]
provider = "anthropic"
name = "claude-sonnet-4-6"
api_key_env = "ANTHROPIC_API_KEY"
native_tool_calling = true
price_per_input_token_usd = 3e-6
price_per_output_token_usd = 15e-6

[[mcp_servers]]
name = "echo-clock"
transport = "stdio"
command = "python"
args = ["-m", "mcp_servers.echo_clock.server"]

[[permissions]]
server = "echo-clock"
tool = "echo"

[[permissions]]
server = "echo-clock"
tool = "clock"

[otel]
enabled = false
service_name = "agent-runtime"
