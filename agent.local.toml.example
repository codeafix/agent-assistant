# Example config for running the same agent against a local OpenAI-compatible
# endpoint (llama.cpp's `llama-server`, vLLM, etc).
#
# Copy to agent.toml (or override via env vars, see below). Everything else
# -- the loop, MCP tools, permissions, skills -- is unchanged from agent.toml.
#
# Set native_tool_calling = false if the local model has no function-calling
# support; the agent will fall back to agent/models/prompted_tools.py.
#
# Equivalent without copying the file, override via env vars:
#   AGENT_MODEL__PROVIDER=openai_compat \
#   AGENT_MODEL__NAME=qwen2.5-7b-instruct \
#   AGENT_MODEL__BASE_URL=http://localhost:8080/v1 \
#   AGENT_MODEL__NATIVE_TOOL_CALLING=false \
#   uv run python -m agent "Please echo 'hello'."

[model]
provider = "openai_compat"
name = "qwen2.5-7b-instruct"
base_url = "http://localhost:8080/v1"
native_tool_calling = false

[[mcp_servers]]
name = "echo-clock"
transport = "stdio"
command = "python"
args = ["-m", "mcp_servers.echo_clock.server"]

[[permissions]]
server = "echo-clock"
tool = "echo"

[[permissions]]
server = "echo-clock"
tool = "clock"

[otel]
enabled = false
service_name = "agent-runtime"
